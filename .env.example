PORT=3000
HOST=0.0.0.0
NODE_ENV=production

JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here
ADMIN_SESSION_TIMEOUT=86400000
API_KEY_PREFIX=cr_

# Optional. If omitted, setup will generate them.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-this-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLE_TLS=

CLAUDE_API_URL=https://api.anthropic.com/v1/messages
CLAUDE_API_VERSION=2023-06-01
CLAUDE_BETA_HEADER=claude-code-20250219,oauth-2025-04-20,interleaved-thinking-2025-05-14,fine-grained-tool-streaming-2025-05-14

DEFAULT_PROXY_TIMEOUT=60000
MAX_PROXY_RETRIES=3
PROXY_USE_IPV4=true

# Optional. System-wide outbound proxy for OAuth refresh / token exchange fallback.
# Examples:
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=socks5://user:pass@127.0.0.1:1080
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=
# HTTP_PROXY=

DEFAULT_TOKEN_LIMIT=1000000

LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

CLEANUP_INTERVAL=3600000
TOKEN_USAGE_RETENTION=2592000000
HEALTH_CHECK_INTERVAL=60000
SYSTEM_TIMEZONE=Asia/Shanghai
TIMEZONE_OFFSET=8

WEB_TITLE=Safe Claude
WEB_DESCRIPTION=Run your own Claude gateway
WEB_LOGO_URL=/assets/logo.png
WEB_SESSION_SECRET=change-this-session-secret
ENABLE_CORS=true
TRUST_PROXY=false

ALLOW_CUSTOM_CLIENTS=false

WEBHOOK_ENABLED=true
WEBHOOK_URLS=
WEBHOOK_TIMEOUT=10000
WEBHOOK_RETRIES=3

# Optional. Enables admin update checks against a GitHub releases feed.
# Example: your-org/safe-claude
GITHUB_RELEASE_REPO=

DEBUG=false
HOT_RELOAD=false

# WireGuard server on the home-side Linux host
WG_INTERFACE=wg-home
WG_ADDRESS=10.14.0.1/24
WG_LISTEN_PORT=51820
WG_PRIVATE_KEY=replace-with-home-private-key

# Relay host peer
WG_CLIENT_PUBLIC_KEY=replace-with-relay-public-key
WG_CLIENT_ALLOWED_IP=10.14.0.2/32

# The outbound WAN interface on the home-side Linux host
WAN_INTERFACE=eth0

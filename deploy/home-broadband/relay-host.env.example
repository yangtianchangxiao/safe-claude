# Local tinyproxy that Claude Code / relay will use
PROXY_SERVICE_NAME=tinyproxy-claude
PROXY_USER=claudeproxy
PROXY_PORT=18443
PROXY_LISTEN=127.0.0.1
PROXY_TIMEOUT=600
PROXY_MAX_CLIENTS=100

# WireGuard client on the relay host
WG_INTERFACE=wg-claude
WG_ADDRESS=10.14.0.2/24
WG_PRIVATE_KEY=replace-with-relay-private-key
WG_PEER_PUBLIC_KEY=replace-with-home-public-key
WG_ENDPOINT=home.example.com:51820
WG_ALLOWED_IPS=0.0.0.0/0
WG_PERSISTENT_KEEPALIVE=25

# Route only the proxy user's traffic into this table
WG_ROUTE_TABLE_ID=184
